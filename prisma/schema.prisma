generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Field {
  id          String   @id @default(uuid()) @map("id")
  name        String   @map("name")
  location    String   @map("location")
  description String?  @map("description")
  price       Int      @map("price")
  type        String   @map("type")
  size        String   @map("size")
  capacity    Int      @map("capacity")
  rating      Float    @default(0) @map("rating")
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bookings    Booking[]
  schedules   FieldSchedule[]
  reviews     Review[]

  @@map("field")
}

model FieldSchedule {
  id          String   @id @default(uuid()) @map("id")
  fieldId     String   @map("field_id")
  field       Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  date        DateTime @map("date")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([fieldId, date, startTime])
  @@map("field_schedule")
}

model Booking {
  id            String   @id @default(uuid()) @map("id")
  fieldId       String   @map("field_id")
  field         Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  bookingDate   DateTime @map("booking_date")
  startTime     String   @map("start_time")
  endTime       String   @map("end_time")
  durationHours Int      @map("duration_hours")
  totalPrice    Int      @map("total_price")
  customerName  String   @map("customer_name")
  customerPhone String   @map("customer_phone")
  customerEmail String   @map("customer_email")
  status        String   @default("pending") @map("status")
  notes         String?  @map("notes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  payments      Payment[]
  invoice       Invoice?
  reviews       Review[]

  @@map("booking")
}

model Payment {
  id            String   @id @default(uuid()) @map("id")
  bookingId     String   @map("booking_id")
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  transactionId String   @unique @map("transaction_id")
  amount        Int      @map("amount")
  paymentMethod String   @default("Midtrans") @map("payment_method")
  provider      String   @default("Midtrans") @map("provider")
  status        String   @default("pending") @map("status")
  paidAt        DateTime? @map("paid_at")
  expiredAt     DateTime? @map("expired_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  invoice       Invoice?

  @@map("payment")
}

model Invoice {
  id            String   @id @default(uuid()) @map("id")
  invoiceNumber String   @unique @map("invoice_number")
  bookingId     String   @unique @map("booking_id")
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentId     String   @unique @map("payment_id")
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  subtotal      Int      @map("subtotal")
  tax           Int      @default(0) @map("tax")
  discount      Int      @default(0) @map("discount")
  total         Int      @map("total")
  status        String   @default("issued") @map("status")
  issuedAt      DateTime @default(now()) @map("issued_at")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("invoice")
}

model Review {
  id           String   @id @default(uuid()) @map("id")
  fieldId      String?  @map("field_id")
  field        Field?   @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  bookingId    String?  @map("booking_id")
  booking      Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  customerName String   @map("customer_name")
  rating       Int      @map("rating")
  comment      String   @map("comment")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("review")
}

model AuditLog {
  id             String   @id @default(uuid()) @map("id")
  action         String   @map("action")
  entity         String   @map("entity")
  entityId       String   @map("entity_id")
  changes        String?  @map("changes")
  ipAddress      String?  @map("ip_address")
  referenceEmail String?  @map("reference_email")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("audit_log")
}

model AdminSetting {
  id          String   @id @default(uuid()) @map("id")
  key         String   @unique @map("key")
  value       String   @map("value")
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("admin_setting")
}
